# Auto detect text files and perform LF or CRLF normalization

.gitattributes text eol=lf
.gitignore text eol=lf

*.sh text eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

*.md text eol=lf

.bashrc text eol=lf

*.conf text eol=lf
*.fish text eol=lf

nanorc text eol=lf
*.nanorc text eol=lf